{
  "manifest_version": 3,
  "name": "看得清 Readable Output for OpenClaw Web",
  "version": "0.1.0",
  "description": "Covers the OpenClaw Web Tool Output sidebar with a readability-first overlay so users can scan conclusion, risks, and next steps before opening the raw text.",
  "permissions": [
    "storage",
    "tabs"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "看得清 Readable Output",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    }
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "commands": {
    "toggle-overlay": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "Toggle the Readable Output overlay on or off"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.openclaw.ai/*",
        "http://localhost/*",
        "http://localhost:*/*",
        "http://127.0.0.1/*",
        "http://127.0.0.1:*/*"
      ],
      "js": [
        "readable-engine.global.js",
        "extension-state.js",
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
